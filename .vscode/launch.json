{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "vs-attach",
            "type": "debugpy",
            "request": "attach",
            "connect": { "host": "127.0.0.1", "port": 5678 },
            "justMyCode": false,
            "subProcess": false
        },
        {
            "name": "ds",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {},
            "cwd": "${workspaceFolder}",
            "program": 
                "train_gpt.py",
                // "ds.py",
            "args": []
        },
        {
            "name": "vs-py",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {},
            "cwd": "${workspaceFolder}",
            "program": "1xgpu_dist_train_moe.py",
            "args": [
                "-lbloss", 
                // "-bf16"
            ]
        },
        {
            "name": "vs-pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [
                "-s",  // capture print()/logging output
                //" --maxfail=1",
                "test_*.py::test_name"
            ],
            "justMyCode": false
        }
    ]
}
